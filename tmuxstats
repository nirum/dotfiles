#!/bin/sh

# CPU: sample over 1 second for actual utilization
cpu=$(top -l 2 -s 1 -n 0 | grep -m1 'CPU usage' | tail -1 | awk -F'[ %]+' '{for(i=1;i<=NF;i++) if($i=="idle") print 100-$(i-1)}')

# Memory: percent used
mem=$(memory_pressure | awk '/percentage/{gsub(/%/,""); print 100 - $5; exit}')

# Battery: only shown if present
batt=""
if pmset -g batt | grep -q InternalBattery; then
    pct=$(pmset -g batt | grep -o '[0-9]\+%' | head -1)
    batt=" о‚і п–ѓ $pct"
fi

printf "о‚і пћ™ %.1f%% о‚і пЎљ %s%%%s\n" "$cpu" "$mem" "$batt"
